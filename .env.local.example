# Groq - https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Mem0 - https://app.mem0.ai
MEM0_API_KEY=your_mem0_api_key_here

# Supabase - https://supabase.com/dashboard
# Used by the browser client and server OAuth callback (anon + public URL).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Server-only: profile sync / admin operations (never expose to the client).
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Site URL for OAuth redirects — use localhost in dev; set your Vercel URL in production env.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
